#include <iostream>
#include <vector>
using namespace std;

int main() 
{
    int n;
    cin>>n;
    vector<int> a(n);
    for(auto &i: a){
      cin>>i;
    }
    int res = 0;
    for(int i =0;i<31;i++){
      int ones = 0, ctr=0;
      for(auto &j: a){
        if(j & (1<<i)){
          res+=ctr-ones;
          ones++;
        }
        else{
          res+=ones;
        }
        ctr++;
      }
    }
    cout<<res*2;
    return 0;
}
